---
import SectionHeader from "./SectionHeader.astro";
import { faqs } from "../config";
---

<section id="faq" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28">
  <div class="reveal">
    <SectionHeader eyebrow="FAQ" title="No trapdoors. Just answers." />
  </div>

  <div
    class="reveal mx-auto mt-12 max-w-3xl divide-y divide-border overflow-hidden rounded-card border border-border bg-surface/40"
  >
    {
      faqs.map((f) => (
        <details class="group faq">
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-medium text-text"
          >
            <span>{f.q}</span>
            <svg
              class="shrink-0 text-muted transition-transform duration-200 group-open:rotate-180"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <p class="px-5 pb-5 text-sm leading-relaxed text-muted" set:html={f.a} />
        </details>
      ))
    }
  </div>
</section>

<style>
  /* Hide the native disclosure marker; we draw our own chevron. */
  .faq > summary::-webkit-details-marker {
    display: none;
  }
</style>
