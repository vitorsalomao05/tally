---
import SectionHeader from "./SectionHeader.astro";

const steps = [
  {
    n: "01",
    title: "Install",
    body: "One command installs the Übersicht widget, or grab the menu bar app. Native Swift, Apple Silicon, ~6 MB — no Electron, no background browser.",
  },
  {
    n: "02",
    title: "Connect",
    body: "Already run Claude Code? Tally reuses its token automatically — zero setup. Otherwise, sign in to Claude.ai once in a secure window; the session stays in your Keychain.",
  },
  {
    n: "03",
    title: "Glance",
    body: "Your tightest limit shows right in the menu bar, color-coded. Open the popover for every window, its reset time, and any extra-usage spend.",
  },
];
---

<section id="how" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28">
  <div class="reveal">
    <SectionHeader
      eyebrow="How it works"
      title="From install to glance in under a minute."
      subtitle="No account to create, no server to trust. Tally reads the usage numbers you already have access to and surfaces them where you can see them."
    />
  </div>

  <ol class="mt-14 grid gap-4 md:grid-cols-3">
    {
      steps.map((step, i) => (
        <li
          class="reveal rounded-card border border-border bg-surface/50 p-6"
          style={`--reveal-delay: ${i * 90}ms`}
        >
          <span class="bg-gradient-to-br from-accent to-violet bg-clip-text font-mono text-3xl font-semibold text-transparent">
            {step.n}
          </span>
          <h3 class="mt-4 text-lg font-semibold">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{step.body}</p>
        </li>
      ))
    }
  </ol>
</section>
