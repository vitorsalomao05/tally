---
import SectionHeader from "./SectionHeader.astro";

const steps = [
  {
    n: "01",
    title: "Install",
    body: "One line installs Houdini — ad-hoc signed, so it opens with no Gatekeeper prompt. Native Swift, Apple Silicon, ~6 MB. No Electron, no background browser.",
  },
  {
    n: "02",
    title: "Connect",
    body: "Already run Claude Code? Houdini reuses its token automatically — zero setup. Otherwise you sign in to claude.ai once in a native window; the session stays in your Keychain.",
  },
  {
    n: "03",
    title: "Reveal",
    body: "Your tightest limit appears in the menu bar, color-coded. Open the popover for every window, its reset time, and any extra-usage spend — refreshed every 60 seconds.",
  },
];
---

<section id="how" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28">
  <div class="reveal">
    <SectionHeader
      eyebrow="How it works"
      title="From install to the reveal in under a minute."
      subtitle="No account to create, no server to trust. Houdini reads the usage numbers you already have a right to — and pulls them into the light."
    />
  </div>

  <ol class="mt-14 grid gap-4 md:grid-cols-3">
    {
      steps.map((step, i) => (
        <li
          class="reveal rounded-card border border-border bg-surface/50 p-6"
          style={`--reveal-delay: ${i * 90}ms`}
        >
          <span class="bg-gradient-to-br from-accent to-magenta bg-clip-text font-display text-3xl font-semibold text-transparent">
            {step.n}
          </span>
          <h3 class="mt-4 text-lg font-semibold">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{step.body}</p>
        </li>
      ))
    }
  </ol>
</section>
