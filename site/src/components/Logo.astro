---
// Wordmark: the top-hat mark (the brand's reveal) + "Houdini".
interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;
---

<span class={`inline-flex items-center gap-2.5 ${cls}`}>
  <svg
    width="26"
    height="26"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    class="shrink-0"
  >
    <defs>
      <linearGradient id="logo-b" x1="16" y1="2" x2="16" y2="30" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#1E1A2B"></stop>
        <stop offset="1" stop-color="#0B0A10"></stop>
      </linearGradient>
      <linearGradient id="logo-a" x1="8" y1="23" x2="24" y2="8" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#7C3AED"></stop>
        <stop offset="1" stop-color="#C026D3"></stop>
      </linearGradient>
    </defs>
    <rect x="1" y="1" width="30" height="30" rx="7" fill="url(#logo-b)" stroke="#3A3357"></rect>
    <rect x="5" y="20.4" width="22" height="3.4" rx="1.7" fill="url(#logo-a)"></rect>
    <path d="M11 23 V11.5 a2 2 0 0 1 2 -2 H19 a2 2 0 0 1 2 2 V23 Z" fill="url(#logo-a)"></path>
    <rect x="11" y="17.4" width="10" height="2.2" fill="#F5C451"></rect>
    <path d="M25 8.4 C 25.5 9.9, 26.1 10.5, 27.6 11 C 26.1 11.5, 25.5 12.1, 25 13.6 C 24.5 12.1, 23.9 11.5, 22.4 11 C 23.9 10.5, 24.5 9.9, 25 8.4 Z" fill="#F5C451"></path>
  </svg>
  <span class="font-display text-[19px] font-semibold tracking-tight text-text">Houdini</span>
</span>
