---
// Wordmark + the gauge mark (the product's signature: stacked usage bars).
interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;
---

<span class={`inline-flex items-center gap-2.5 ${cls}`}>
  <svg
    width="26"
    height="26"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    class="shrink-0"
  >
    <defs>
      <linearGradient id="logo-g" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#3B82F6"></stop>
        <stop offset="1" stop-color="#7C5CFF"></stop>
      </linearGradient>
    </defs>
    <rect x="1" y="1" width="30" height="30" rx="8" fill="#14161B" stroke="#232733"></rect>
    <rect x="8" y="10" width="16" height="3" rx="1.5" fill="#232733"></rect>
    <rect x="8" y="10" width="11" height="3" rx="1.5" fill="url(#logo-g)"></rect>
    <rect x="8" y="16" width="16" height="3" rx="1.5" fill="#232733"></rect>
    <rect x="8" y="16" width="6" height="3" rx="1.5" fill="#34D399"></rect>
    <rect x="8" y="22" width="16" height="3" rx="1.5" fill="#232733"></rect>
    <rect x="8" y="22" width="14" height="3" rx="1.5" fill="#F5A623"></rect>
  </svg>
  <span class="text-[17px] font-semibold tracking-tight text-text">Houdini</span>
</span>
