---
const items = [
  {
    label: "Runs entirely on your Mac",
    path: "M12 2 4 5v6c0 5 3.4 8.3 8 10 4.6-1.7 8-5 8-10V5l-8-3Z",
  },
  {
    label: "Credentials stay in your Keychain",
    path: "M7 11V8a5 5 0 0 1 10 0v3m-11 0h12a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1Z",
  },
  {
    label: "Open source",
    path: "m9 18-6-6 6-6m6 0 6 6-6 6",
  },
];
---

<section class="border-y border-border/60 bg-surface/30">
  <ul
    class="mx-auto flex max-w-6xl flex-col gap-3 px-5 py-5 sm:flex-row sm:items-center sm:justify-center sm:gap-10 sm:px-8"
  >
    {
      items.map((item) => (
        <li class="flex items-center justify-center gap-2.5 text-sm text-muted">
          <svg
            width="17"
            height="17"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-accent"
            aria-hidden="true"
          >
            <path d={item.path} />
          </svg>
          {item.label}
        </li>
      ))
    }
  </ul>
</section>
