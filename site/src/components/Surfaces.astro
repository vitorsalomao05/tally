---
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";
import ubersichtPreview from "../assets/ubersicht-preview.png";
import { links } from "../config";

// A native render of Tally's gauge language (the product's signature), so it
// lives in the DOM and not only inside the screenshots. Illustrative sample.
const gauges = [
  { label: "5-hour", pct: 34, bar: "bg-ok", text: "text-ok" },
  { label: "Weekly", pct: 72, bar: "bg-warn", text: "text-warn" },
  { label: "Opus weekly", pct: 91, bar: "bg-danger", text: "text-danger" },
];
---

<section
  id="surfaces"
  class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28"
>
  <div class="reveal">
    <SectionHeader
      eyebrow="Surfaces"
      title="See your usage wherever you look."
      subtitle="One shared data core, wherever you glance — menu bar, desktop, and soon your iPhone. Pick the surface that fits your workflow."
    />
  </div>

  <div class="mt-14 grid gap-4 md:grid-cols-2">
    <!-- Flagship: menu bar app -->
    <article class="reveal ring-grad flex flex-col overflow-hidden rounded-card">
      <div class="p-6 sm:p-7">
        <div class="flex items-center justify-between gap-2">
          <span
            class="inline-flex items-center gap-1.5 rounded-full bg-accent/12 px-2.5 py-1 font-mono text-[11px] uppercase tracking-wider text-accent"
          >
            Flagship
          </span>
          <span class="inline-flex items-center gap-1.5 font-mono text-xs text-accent">
            <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>Signed app soon
          </span>
        </div>
        <h3 class="mt-5 text-xl font-semibold">Menu bar app</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted">
          The full experience. Your tightest limit lives in the menu bar; click for
          a popover with every window, reset timer, and overage — refreshed every
          60 seconds. Build it from source today; the signed download is next.
        </p>
        <ul class="mt-5 flex flex-wrap gap-2 font-mono text-xs text-muted">
          <li class="rounded-md border border-border bg-surface-2/60 px-2 py-1">SwiftUI MenuBarExtra</li>
          <li class="rounded-md border border-border bg-surface-2/60 px-2 py-1">True 60s refresh</li>
          <li class="rounded-md border border-border bg-surface-2/60 px-2 py-1">~6 MB</li>
        </ul>
      </div>
      <div class="mt-auto border-t border-border/60 bg-surface-2/40 p-4">
        <div class="space-y-3 rounded-lg border border-border/60 bg-surface p-4">
          {
            gauges.map((g) => (
              <div>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-muted">{g.label}</span>
                  <span class={`font-mono text-xs ${g.text}`}>{g.pct}%</span>
                </div>
                <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-surface-2">
                  <div class={`h-full rounded-full ${g.bar}`} style={`width:${g.pct}%`} />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </article>

    <!-- Übersicht widget with real preview -->
    <article
      class="reveal flex flex-col overflow-hidden rounded-card border border-border bg-surface/50"
    >
      <div class="flex items-center justify-between p-6 pb-4 sm:px-7">
        <h3 class="text-xl font-semibold">Übersicht desktop widget</h3>
        <span class="inline-flex items-center gap-1.5 font-mono text-xs text-ok">
          <span class="h-1.5 w-1.5 rounded-full bg-ok" aria-hidden="true"></span>Live · every 60s
        </span>
      </div>
      <p class="px-6 text-sm leading-relaxed text-muted sm:px-7">
        Prefer it on the desktop? The same gauges, pinned to your wallpaper via
        Übersicht. Installs with one script.
      </p>
      <div class="mt-5 border-t border-border/60 bg-surface-2/40 p-4">
        <Image
          src={ubersichtPreview}
          alt="The Tally Übersicht desktop widget showing Claude usage rows — label, percentage, and a threshold-colored bar — on the desktop."
          widths={[400, 700, 1000]}
          sizes="(max-width: 768px) 90vw, 500px"
          class="block w-full rounded-lg border border-border/60"
          loading="lazy"
        />
      </div>
    </article>

    <!-- Notification Center — honest coming soon -->
    <article
      class="reveal flex flex-col gap-2 rounded-card border border-dashed border-border bg-surface/30 p-6 sm:col-span-2 sm:flex-row sm:items-center sm:justify-between sm:p-7"
    >
      <div>
        <div class="flex items-center gap-3">
          <h3 class="text-xl font-semibold text-muted">Notification Center widget</h3>
          <span
            class="rounded-full border border-border bg-surface px-2.5 py-1 font-mono text-[11px] uppercase tracking-wider text-muted"
          >
            Coming soon
          </span>
        </div>
        <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">
          A glanceable WidgetKit widget for Notification Center. It won't hit 60s —
          Apple budgets widget refreshes to roughly every 15 minutes — so we'll ship
          it with honest "updated a few minutes ago" copy rather than fake a live gauge.
        </p>
      </div>
    </article>

    {/* iPhone app — "in development", links to the real tracking issue */}
    <article
      class="reveal flex flex-col gap-3 rounded-card border border-dashed border-accent/30 bg-surface/30 p-6 sm:col-span-2 sm:flex-row sm:items-center sm:justify-between sm:p-7"
    >
      <div>
        <div class="flex items-center gap-3">
          <h3 class="text-xl font-semibold">Tally for iPhone</h3>
          <span
            class="inline-flex items-center gap-1.5 rounded-full bg-accent/12 px-2.5 py-1 font-mono text-[11px] uppercase tracking-wider text-accent"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>In development
          </span>
        </div>
        <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">
          A native iOS app with Home Screen and Lock Screen widgets. You sign in to
          Claude.ai once; your session stays in the iPhone's Keychain — no server, same
          privacy promise as the Mac app. It's a real app, not a web page: a browser
          can't reach your usage without a server seeing your login, so the honest path
          is native. Widgets refresh on Apple's ~15-minute budget, not 60s.
        </p>
      </div>
      <a
        href={links.iosTracking}
        target="_blank"
        rel="noopener"
        class="inline-flex shrink-0 items-center gap-2 self-start rounded-full border border-border bg-surface px-4 py-2 text-sm font-medium text-text transition-colors hover:border-accent/60 hover:text-white sm:self-center"
      >
        Follow on GitHub
        <span aria-hidden="true">→</span>
      </a>
    </article>
  </div>
</section>
