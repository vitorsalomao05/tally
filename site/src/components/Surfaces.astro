---
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";
import desktopWidget from "../assets/desktop-widget.png";

// A native render of Houdini's gauge language (the product's signature), so it
// lives in the DOM and not only inside the screenshots. Illustrative sample.
const gauges = [
  { label: "5-hour", pct: 34, bar: "bg-ok", text: "text-ok" },
  { label: "Weekly", pct: 72, bar: "bg-warn", text: "text-warn" },
  { label: "Opus weekly", pct: 91, bar: "bg-danger", text: "text-danger" },
];
---

<section
  id="surfaces"
  class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28"
>
  <div class="reveal">
    <SectionHeader
      eyebrow="Where it shows up"
      title="In the menu bar, on your desktop — one app."
      subtitle="The same Houdini, the same data, the same true 60-second refresh — revealed wherever it fits your workflow. Both are built in; pick one or run both."
    />
  </div>

  <div class="mt-14 grid gap-4 md:grid-cols-2">
    <!-- Menu bar — native, with a live render of the gauge language -->
    <article class="reveal flex flex-col overflow-hidden rounded-card border border-border bg-surface/50">
      <div class="p-6 sm:p-7">
        <div class="flex items-center justify-between gap-2">
          <h3 class="text-xl font-semibold">Menu bar</h3>
          <span class="inline-flex items-center gap-1.5 font-mono text-xs text-ok">
            <span class="h-1.5 w-1.5 rounded-full bg-ok" aria-hidden="true"></span>Live · every 60s
          </span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          Your tightest limit sits in the menu bar. Click for a popover with every
          window, its reset timer, and any overage — refreshed every 60 seconds.
        </p>
      </div>
      <div class="mt-auto border-t border-border/60 bg-surface-2/40 p-4">
        <div class="space-y-3 rounded-lg border border-border/60 bg-surface p-4">
          {
            gauges.map((g) => (
              <div>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-muted">{g.label}</span>
                  <span class={`font-mono text-xs ${g.text}`}>{g.pct}%</span>
                </div>
                <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-surface-2">
                  <div class={`h-full rounded-full ${g.bar}`} style={`width:${g.pct}%`} />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </article>

    <!-- Desktop widget — native, with a real preview -->
    <article class="reveal flex flex-col overflow-hidden rounded-card border border-border bg-surface/50">
      <div class="p-6 pb-3 sm:px-7">
        <div class="flex items-center justify-between gap-2">
          <h3 class="text-xl font-semibold">Desktop widget</h3>
          <span class="inline-flex items-center gap-1.5 font-mono text-xs text-ok">
            <span class="h-1.5 w-1.5 rounded-full bg-ok" aria-hidden="true"></span>Live · every 60s
          </span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          Prefer it on the desktop? The same gauges, pinned to your wallpaper —
          part of the app, not a separate install.
        </p>
      </div>
      <div class="mt-auto border-t border-border/60 bg-surface-2/40 p-4">
        <Image
          src={desktopWidget}
          alt="The Houdini desktop widget showing Claude usage rows — label, percentage, and a threshold-colored bar — pinned to the desktop."
          widths={[400, 700, 1000]}
          sizes="(max-width: 768px) 90vw, 500px"
          class="block w-full rounded-lg border border-border/60"
          loading="lazy"
        />
      </div>
    </article>
  </div>
</section>
