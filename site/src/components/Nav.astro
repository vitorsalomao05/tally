---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import { nav, links } from "../config";
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-border/60 bg-bg/70 backdrop-blur-xl"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-5 sm:px-8"
    aria-label="Primary"
  >
    <a href="/#top" class="rounded-lg" aria-label="Houdini — top of page">
      <Logo />
    </a>

    <ul class="hidden items-center gap-7 md:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm text-muted transition-colors hover:text-text"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={links.github}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg p-2 text-muted transition-colors hover:text-text"
        aria-label="Houdini on GitHub"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.2-3.1-.12-.3-.52-1.47.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.22-1.5 3.2-1.18 3.2-1.18.63 1.58.23 2.75.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"
          ></path>
        </svg>
      </a>
      <Button href="/#install" variant="primary">Get Houdini</Button>
    </div>
  </nav>
</header>
