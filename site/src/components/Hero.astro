---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import WindowFrame from "./WindowFrame.astro";
import { links } from "../config";
import popoverDark from "../assets/popover-dark.png";
---



<section id="top" class="relative overflow-hidden pt-28 sm:pt-36">
  <!-- the stage spotlight, behind the headline -->
  <div
    class="spotlight pointer-events-none absolute -top-44 right-[-12%] -z-10 h-[560px] w-[560px] opacity-70"
    aria-hidden="true"
  >
  </div>
  <div class="stage-grid pointer-events-none absolute inset-0 -z-10 h-[640px]" aria-hidden="true"></div>

  <div
    class="mx-auto grid max-w-6xl items-center gap-14 px-5 pb-20 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-10 lg:pb-28"
  >
    <div class="reveal flex flex-col items-start gap-6">
      <!-- The reveal: the top-hat mark settles, then a gold spark escapes. -->
      <div class="hero-logo" aria-hidden="true">
        <svg width="60" height="60" viewBox="0 0 32 32" fill="none">
          <defs>
            <linearGradient id="hm-hat" x1="6" y1="26" x2="26" y2="6" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="#7C3AED"></stop>
              <stop offset="0.55" stop-color="#8B5CF6"></stop>
              <stop offset="1" stop-color="#C026D3"></stop>
            </linearGradient>
            <linearGradient id="hm-shimmer" x1="0" y1="0" x2="6" y2="0" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="#FFFFFF" stop-opacity="0"></stop>
              <stop offset="0.5" stop-color="#FFFFFF" stop-opacity="0.55"></stop>
              <stop offset="1" stop-color="#FFFFFF" stop-opacity="0"></stop>
            </linearGradient>
            <clipPath id="hm-crown">
              <path d="M11 22.6 L9.7 11 Q9.6 8.6 12.1 8.6 L19.9 8.6 Q22.4 8.6 22.3 11 L21 22.6 Z"></path>
            </clipPath>
          </defs>
          <g class="hm-hat">
            <ellipse cx="16" cy="23.2" rx="12.4" ry="3" fill="url(#hm-hat)"></ellipse>
            <ellipse cx="16" cy="22.5" rx="12.4" ry="2.4" fill="#000000" opacity="0.12"></ellipse>
            <path d="M11 22.6 L9.7 11 Q9.6 8.6 12.1 8.6 L19.9 8.6 Q22.4 8.6 22.3 11 L21 22.6 Z" fill="url(#hm-hat)"></path>
            <g clip-path="url(#hm-crown)">
              <path d="M11 16 L9.7 11 Q9.6 8.6 12.1 8.6 L19.9 8.6 Q22.4 8.6 22.3 11 L21.6 16 Z" fill="#FFFFFF" opacity="0.10"></path>
              <rect x="8" y="17.6" width="16" height="2.9" fill="#F5C451"></rect>
              <rect x="8" y="17.6" width="16" height="0.9" fill="#FFFFFF" opacity="0.25"></rect>
              <rect class="hm-shimmer" x="0" y="6" width="6" height="20" fill="url(#hm-shimmer)"></rect>
            </g>
          </g>
          <g transform="translate(25 6.6)"><g class="hm-spark">
            <path d="M0 -4.4 C0.7 -1.3 1.3 -0.7 4.4 0 C1.3 0.7 0.7 1.3 0 4.4 C-0.7 1.3 -1.3 0.7 -4.4 0 C-1.3 -0.7 -0.7 -1.3 0 -4.4 Z" fill="#F5C451"></path>
          </g></g>
          <g transform="translate(21.2 3)"><g class="hm-spark hm-spark--sm">
            <path d="M0 -1.9 C0.3 -0.57 0.57 -0.3 1.9 0 C0.57 0.3 0.3 0.57 0 1.9 C-0.3 0.57 -0.57 0.3 -1.9 0 C-0.57 -0.3 -0.3 -0.57 0 -1.9 Z" fill="#F5C451" opacity="0.85"></path>
          </g></g>
        </svg>
      </div>

      <span
        class="inline-flex items-center gap-2 rounded-full border border-border bg-surface/60 px-3 py-1 font-mono text-xs text-muted"
      >
        <span class="relative flex h-2 w-2" aria-hidden="true">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-ok opacity-60"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-ok"></span>
        </span>
        Live for Claude Pro · Max
      </span>

      <h1
        class="font-display text-[2.6rem] font-semibold leading-[1.04] sm:text-6xl"
      >
        See your AI usage<br class="hidden sm:block" /> and spend,
        <span class="text-reveal">revealed</span>.
      </h1>

      <p class="max-w-xl text-lg leading-relaxed text-muted">
        Houdini reveals what your AI is really costing you — your Claude limits,
        reset timers, and extra-usage dollars, refreshed every 60 seconds. In
        your menu bar and on your desktop. No account, no server. Nothing leaves
        your Mac.
      </p>

      <div class="flex flex-wrap items-center gap-3 pt-1">
        <Button href={links.install} variant="primary" size="lg">Install Houdini</Button>
        <Button href={links.guide} variant="secondary" size="lg">How it works</Button>
      </div>

      <p class="font-mono text-xs text-muted/80">
        macOS 14+ · Apple Silicon · free, local-first &amp; open source
      </p>
    </div>

    <div class="reveal" style="--reveal-delay: 120ms">
      <WindowFrame title="Houdini" glow class="mx-auto max-w-[360px]">
        <Image
          src={popoverDark}
          alt="Houdini's menu bar popover showing Claude usage: a 5-hour session window, weekly and Sonnet-weekly caps, and extra-usage spend, each with a color-coded gauge and reset time."
          widths={[320, 360, 720]}
          sizes="(max-width: 1024px) 80vw, 360px"
          class="block w-full"
          loading="eager"
        />
      </WindowFrame>
    </div>
  </div>
</section>

<style>
  /* Hero logo reveal: the hat settles, a gold spark pops, a shimmer sweeps once. */
  .hero-logo .hm-hat {
    transform-box: fill-box;
    transform-origin: 50% 100%;
    animation: hatSettle 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s both;
  }
  .hero-logo .hm-spark {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: sparkPop 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) 0.55s both;
  }
  .hero-logo .hm-spark--sm {
    animation-delay: 0.72s;
  }
  .hero-logo .hm-shimmer {
    transform-box: fill-box;
    opacity: 0;
    animation: shimmerSweep 1s ease 0.85s 1 both;
  }

  @keyframes hatSettle {
    0% { opacity: 0; transform: translateY(3px) scale(0.92); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes sparkPop {
    0% { opacity: 0; transform: scale(0) rotate(-30deg); }
    55% { opacity: 1; transform: scale(1.25) rotate(10deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  @keyframes shimmerSweep {
    0% { opacity: 0; transform: translateX(-2px); }
    12% { opacity: 1; }
    88% { opacity: 1; }
    100% { opacity: 0; transform: translateX(22px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-logo .hm-hat,
    .hero-logo .hm-spark,
    .hero-logo .hm-shimmer {
      animation: none;
    }
    .hero-logo .hm-hat,
    .hero-logo .hm-spark { opacity: 1; transform: none; }
    .hero-logo .hm-shimmer { opacity: 0; }
  }
</style>
