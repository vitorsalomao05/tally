---
import SectionHeader from "./SectionHeader.astro";
import { reveals } from "../config";

// Inline icon paths keyed by reveal.icon — drawn at 1.7 stroke, currentColor.
const icons: Record<string, string> = {
  gauge: "M12 13a3 3 0 1 0 0-.01M12 13l4-4M5 19a9 9 0 1 1 14 0",
  clock: "M12 7v5l3 2m6-2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
  tokens:
    "M4 7c0 1.1 3.6 2 8 2s8-.9 8-2-3.6-2-8-2-8 .9-8 2Zm0 0v10c0 1.1 3.6 2 8 2s8-.9 8-2V7M4 12c0 1.1 3.6 2 8 2s8-.9 8-2",
  dollar: "M12 3v18m4-14.5C16 5 14.2 4 12 4 9.5 4 8 5.3 8 7s1.5 2.6 4 3 4 1.3 4 3-1.8 3-4 3c-2.2 0-4-1-4-2.5",
};
---

<section id="reveals" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28">
  <div class="reveal">
    <SectionHeader
      eyebrow="What it reveals"
      title="Every number your AI keeps backstage."
      subtitle="Houdini pulls your real limits, timers, and spend into the open — so a throttle or a bill never catches you off guard."
    />
  </div>

  <ul class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      reveals.map((r, i) => (
        <li
          class="reveal flex flex-col gap-3 rounded-card border border-border bg-surface/50 p-5"
          style={`--reveal-delay: ${i * 70}ms`}
        >
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-accent/12 text-accent">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={icons[r.icon]} />
            </svg>
          </span>
          <h3 class="font-semibold leading-tight">{r.title}</h3>
          <p class="text-sm leading-relaxed text-muted">{r.body}</p>
        </li>
      ))
    }
  </ul>
</section>
