---
import SectionHeader from "./SectionHeader.astro";
import CopyBlock from "./CopyBlock.astro";
import { links, installUbersicht, installMenubar } from "../config";
---

<section
  id="install"
  class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28"
>
  <div class="reveal">
    <SectionHeader
      eyebrow="Install"
      title="Get Tally running today."
      subtitle="The Übersicht widget installs right now with one command. The signed menu bar app is the next milestone — until then you can build it from source."
    />
  </div>

  <div class="mt-14 grid gap-4 lg:grid-cols-2">
    <!-- Works today -->
    <div class="reveal flex min-w-0 flex-col gap-4">
      <div class="flex items-center gap-2.5">
        <span class="inline-flex h-2 w-2 rounded-full bg-ok" aria-hidden="true"></span>
        <h3 class="font-semibold">Übersicht widget — works today</h3>
      </div>
      <CopyBlock code={installUbersicht} label="clone & install" />
      <p class="text-sm leading-relaxed text-muted">
        Builds <code class="font-mono text-text">tally-cli</code> and deploys the
        widget. Needs the Xcode Command Line Tools and Übersicht
        (<code class="font-mono text-text">brew install --cask ubersicht</code>).
        Re-run any time — it's idempotent.
      </p>
    </div>

    <!-- Menu bar app — honest coming-soon download -->
    <div class="reveal flex min-w-0 flex-col gap-4" style="--reveal-delay: 100ms">
      <div class="flex items-center gap-2.5">
        <span class="inline-flex h-2 w-2 rounded-full bg-accent" aria-hidden="true"></span>
        <h3 class="font-semibold">Menu bar app — the flagship</h3>
      </div>

      <div class="rounded-card border border-border bg-surface/50 p-6">
        {
          links.downloadDmg ? (
            <a
              href={links.downloadDmg}
              class="group flex items-center justify-center gap-3 rounded-xl bg-accent-strong px-5 py-3.5 font-semibold text-white shadow-lg shadow-accent/25 transition-colors hover:bg-accent-strong-hover"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M16.4 12.6c0-2 1.6-3 1.7-3a3.7 3.7 0 0 0-2.9-1.6c-1.2-.1-2.4.7-3 .7s-1.6-.7-2.6-.7A3.9 3.9 0 0 0 6.3 10c-1.4 2.5-.4 6.1 1 8.1.7 1 1.4 2.1 2.5 2 1-.04 1.3-.6 2.5-.6s1.5.6 2.6.6c1 0 1.7-1 2.4-2a8.6 8.6 0 0 0 1.1-2.2c-.1 0-2.1-.8-2.1-3.3M14.5 5.9c.5-.7.9-1.6.8-2.6-.8 0-1.8.6-2.4 1.3-.5.6-1 1.5-.8 2.4.9.1 1.8-.4 2.4-1.1" />
              </svg>
              Download for Mac (Apple Silicon)
            </a>
          ) : (
            <div
              class="flex flex-col items-center gap-3 rounded-xl border border-accent/40 bg-accent/8 px-5 py-5 text-center"
              role="group"
              aria-label="Menu bar app download — coming soon"
            >
              <span class="inline-flex items-center gap-2.5 text-[15px] font-semibold text-text">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M16.4 12.6c0-2 1.6-3 1.7-3a3.7 3.7 0 0 0-2.9-1.6c-1.2-.1-2.4.7-3 .7s-1.6-.7-2.6-.7A3.9 3.9 0 0 0 6.3 10c-1.4 2.5-.4 6.1 1 8.1.7 1 1.4 2.1 2.5 2 1-.04 1.3-.6 2.5-.6s1.5.6 2.6.6c1 0 1.7-1 2.4-2a8.6 8.6 0 0 0 1.1-2.2c-.1 0-2.1-.8-2.1-3.3M14.5 5.9c.5-.7.9-1.6.8-2.6-.8 0-1.8.6-2.4 1.3-.5.6-1 1.5-.8 2.4.9.1 1.8-.4 2.4-1.1" />
                </svg>
                Download for Mac (Apple Silicon)
              </span>
              <span
                class="rounded-full border border-border bg-surface px-3 py-1 font-mono text-xs text-muted"
              >
                Signed DMG — coming soon
              </span>
            </div>
          )
        }
        <p class="mt-4 text-sm leading-relaxed text-muted">
          We're notarizing a one-click DMG so Gatekeeper opens it cleanly. In the
          meantime, build the real app yourself in a couple of commands:
        </p>
        <div class="mt-3">
          <CopyBlock code={installMenubar} label="build from source" />
        </div>
      </div>
    </div>
  </div>
</section>
