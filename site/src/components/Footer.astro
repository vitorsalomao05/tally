---
import Logo from "./Logo.astro";
import { links, version } from "../config";
---

<footer
  transition:persist="site-footer"
  class="border-t border-border/60"
>
  <div
    class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-5 py-4 text-xs sm:flex-row sm:px-8"
  >
    <a href="/" class="rounded-lg" aria-label="Houdini — home">
      <Logo />
    </a>

    <nav
      class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-muted"
      aria-label="Footer"
    >
      <a href={links.install} class="transition-colors hover:text-text">Install</a>
      <a href="/guide" class="transition-colors hover:text-text">Guide</a>
      <a href="/privacy" class="transition-colors hover:text-text">Privacy</a>
      <a
        href={links.github}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-text">GitHub</a
      >
      <a
        href={links.changelog}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full border border-border bg-surface/50 px-2.5 py-0.5 font-mono transition-colors hover:border-accent/60 hover:text-text"
        aria-label={`Version ${version} — changelog`}
      >
        <span class="h-1.5 w-1.5 rounded-full bg-spark" aria-hidden="true"></span>
        v{version}
      </a>
    </nav>

    <p class="font-mono text-muted/90">Local-first · No trapdoors</p>
  </div>
</footer>
