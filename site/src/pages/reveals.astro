---
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { reveals } from "../config";

// Tab order mirrors config.reveals: Limits · Sessions · Tokens · Spend. Each tab
// reuses the real body copy and pairs it with an on-brand, illustrative render of
// the product's gauge language (the same green/amber/red thresholds the app uses).
const tabs = reveals.map((r, i) => ({ ...r, id: r.title.toLowerCase(), i }));

const limitGauges = [
  { label: "5-hour session", pct: 34, bar: "bg-ok", text: "text-ok" },
  { label: "Weekly", pct: 72, bar: "bg-warn", text: "text-warn" },
  { label: "Opus weekly", pct: 91, bar: "bg-danger", text: "text-danger" },
];
const spark = [38, 52, 44, 67, 59, 81, 73];
---

<Layout
  title="What Houdini reveals — Limits, Sessions, Tokens, Spend"
  description="The four numbers Houdini pulls into the open: your Claude limits, your rolling session window, tokens burned, and extra-usage spend — color-coded and refreshed every 60 seconds."
>
  <main id="main" tabindex="-1" class="screen relative overflow-hidden px-5 pt-24 sm:px-8 md:pt-20">
    <div
      class="screen-glow pointer-events-none absolute -top-20 left-1/2 -z-10 h-[480px] w-[680px] -translate-x-1/2 opacity-70"
      aria-hidden="true"
    >
    </div>

    <div class="screen-inner mx-auto max-w-5xl py-8">
      <div data-enter style="--enter-i: 0">
        <SectionHeader
          eyebrow="What it reveals"
          title="Every number your AI keeps backstage."
          subtitle="Houdini pulls your real limits, timers, and spend into the open — so a throttle or a bill never catches you off guard. Switch between the four."
          align="left"
        />
      </div>

      <div data-tabs data-enter style="--enter-i: 1" class="mt-10">
        <!-- Tablist -->
        <div
          class="no-scrollbar relative flex gap-1 overflow-x-auto border-b border-border"
          role="tablist"
          aria-label="What Houdini reveals"
        >
          {
            tabs.map((t) => (
              <button
                type="button"
                role="tab"
                id={`tab-${t.id}`}
                aria-controls={`panel-${t.id}`}
                aria-selected={t.i === 0 ? "true" : "false"}
                tabindex={t.i === 0 ? 0 : -1}
                class="shrink-0 rounded-t-lg px-4 py-3 text-sm font-medium text-muted transition-colors hover:text-text aria-[selected=true]:text-text"
              >
                {t.title}
              </button>
            ))
          }
          <span class="tab-indicator" data-tab-indicator aria-hidden="true"></span>
        </div>

        <!-- Panels -->
        <div class="mt-7">
          {
            tabs.map((t) => (
              <section
                role="tabpanel"
                id={`panel-${t.id}`}
                aria-labelledby={`tab-${t.id}`}
                tabindex="0"
                class="grid items-center gap-8 rounded-frame border border-border bg-surface/40 p-6 sm:p-8 md:grid-cols-2"
              >
                <div>
                  <h2 class="font-display text-2xl font-semibold sm:text-3xl">
                    {t.title}
                  </h2>
                  <p class="mt-3 text-base leading-relaxed text-muted sm:text-lg">
                    {t.body}
                  </p>
                  <p class="mt-4 font-mono text-xs text-muted/70">
                    Illustrative sample · live in the app every 60s
                  </p>
                </div>

                <div class="rounded-card border border-border/70 bg-surface-2/40 p-5">
                  {/* Limits — three color-coded caps */}
                  {t.id === "limits" && (
                    <div class="space-y-4">
                      {limitGauges.map((g) => (
                        <div>
                          <div class="flex items-center justify-between">
                            <span class="text-sm text-muted">{g.label}</span>
                            <span class={`font-mono text-sm ${g.text}`}>{g.pct}%</span>
                          </div>
                          <div class="mt-1.5 h-2 overflow-hidden rounded-full bg-surface-2">
                            <div class={`h-full rounded-full ${g.bar}`} style={`width:${g.pct}%`} />
                          </div>
                        </div>
                      ))}
                    </div>
                  )}

                  {/* Sessions — the rolling 5-hour window + reset */}
                  {t.id === "sessions" && (
                    <div>
                      <div class="flex items-baseline justify-between">
                        <span class="text-sm text-muted">5-hour window</span>
                        <span class="font-display text-3xl font-semibold text-ok">34%</span>
                      </div>
                      <div class="mt-2 h-2 overflow-hidden rounded-full bg-surface-2">
                        <div class="h-full rounded-full bg-ok" style="width:34%" />
                      </div>
                      <div class="mt-4 flex items-center gap-2 rounded-lg border border-border/60 bg-surface px-3 py-2">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true">
                          <path d="M12 7v5l3 2m6-2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                        <span class="font-mono text-xs text-muted">Resets in 3h 12m</span>
                      </div>
                    </div>
                  )}

                  {/* Tokens — burned this window */}
                  {t.id === "tokens" && (
                    <div>
                      <div class="flex items-baseline justify-between">
                        <span class="text-sm text-muted">This window</span>
                        <span class="font-display text-3xl font-semibold text-text">1.24M</span>
                      </div>
                      <div class="mt-4 flex h-20 items-end gap-1.5" aria-hidden="true">
                        {spark.map((h) => (
                          <div
                            class="flex-1 rounded-t bg-gradient-to-t from-accent/40 to-accent"
                            style={`height:${h}%`}
                          />
                        ))}
                      </div>
                      <p class="mt-3 font-mono text-xs text-muted">tokens, kept current to the minute</p>
                    </div>
                  )}

                  {/* Spend — dollars past plan */}
                  {t.id === "spend" && (
                    <div>
                      <div class="flex items-baseline justify-between">
                        <span class="text-sm text-muted">Extra-usage</span>
                        <span class="font-display text-3xl font-semibold text-danger">
                          $93<span class="text-base text-muted"> / $100</span>
                        </span>
                      </div>
                      <div class="mt-2 h-2 overflow-hidden rounded-full bg-surface-2">
                        <div class="h-full rounded-full bg-danger" style="width:93%" />
                      </div>
                      <p class="mt-4 font-mono text-xs text-muted">
                        Real-time · never a surprise bill
                      </p>
                    </div>
                  )}
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </div>
  </main>
</Layout>
