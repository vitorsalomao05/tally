---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import CopyBlock from "../components/CopyBlock.astro";
import Stepper from "../components/Stepper.astro";
import StepCard from "../components/StepCard.astro";
import { installOneLiner, installFromSource, links, surfaces } from "../config";

// The wizard's cards, in order. Drives the progress count and the deep-link
// slugs (/install#connect, /install#widget, …).
const steps = [
  { slug: "install", label: "Run the command" },
  { slug: "connect", label: "Connect Claude" },
  { slug: "widget", label: "Desktop widget" },
  { slug: "done", label: "You're set" },
];
const total = steps.length;

// Shared classes for the decision toggle buttons.
const choiceClass =
  "stepper-choice flex-1 rounded-card border border-border bg-surface/40 px-4 py-3 text-left text-sm font-medium text-muted transition-colors hover:border-accent/60 hover:text-text aria-[pressed=true]:border-spark/70 aria-[pressed=true]:bg-spark/10 aria-[pressed=true]:text-text";
const panelClass =
  "mt-4 rounded-card border border-border/70 bg-surface-2/40 p-4 text-sm leading-relaxed text-muted";
---

<Layout
  title="Install — Houdini"
  description="A guided setup for Houdini: run one command, connect Claude, choose your surfaces. macOS 14+, Apple Silicon. Nothing leaves your Mac."
>
  <Nav />
  <main id="main" tabindex="-1">
    <!-- Header -->
    <header class="relative overflow-hidden pt-28 sm:pt-36">
      <div
        class="spotlight pointer-events-none absolute -top-40 right-[-10%] -z-10 h-[440px] w-[440px] opacity-60"
        aria-hidden="true"
      >
      </div>
      <div class="mx-auto max-w-3xl px-5 sm:px-8">
        <span
          class="inline-flex items-center gap-2.5 font-mono text-xs uppercase tracking-[0.18em] text-accent"
        >
          <span
            class="inline-block h-[3px] w-6 rounded-full bg-gradient-to-r from-accent to-magenta"
            aria-hidden="true"></span>
          Install
        </span>
        <h1
          class="mt-4 font-display text-[2.4rem] font-semibold leading-[1.06] sm:text-5xl"
        >
          A guided setup, start to finish.
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          One command installs Houdini, it reuses a login you already have, and
          your limits appear in the menu bar. No account, no server — nothing
          leaves your Mac. Step through it below, or read it as one page.
        </p>
        <p class="mt-3 font-mono text-xs text-muted/80">
          macOS 14 (Sonoma)+ · Apple Silicon · free &amp; open source
        </p>
      </div>
    </header>

    <!-- Wizard -->
    <Stepper id="install" label="Install Houdini, step by step" steps={steps} store>
      <!-- 1 · Run the command (same for everyone) -->
      <StepCard
        slug="install"
        index={0}
        total={total}
        badge="1"
        title="Run the command"
        featured
      >
        <p class="text-sm leading-relaxed text-muted">
          Paste this into Terminal. It downloads Houdini and the
          <code class="font-mono text-text">houdini</code> helper from the pinned
          release, <span class="text-text">verifies their SHA-256</span>, then installs
          without <code class="font-mono text-text">sudo</code> — and with no Gatekeeper
          prompt. It offers (never forces) launch-at-login, and re-running is safe.
        </p>
        <div class="mt-5">
          <CopyBlock
            code={installOneLiner}
            label="install · macOS 14+ · Apple Silicon"
          />
        </div>
      </StepCard>

      <!-- 2 · Connect Claude (decision) -->
      <StepCard
        slug="connect"
        index={1}
        total={total}
        badge="2"
        title="Connect Claude"
      >
        <p class="text-sm leading-relaxed text-muted">
          Houdini never asks you to paste a secret into a form. It reuses a
          credential you already have, kept in your macOS Keychain — so how you
          connect depends on one thing:
        </p>
        <div
          class="mt-5 flex flex-col gap-3 sm:flex-row"
          role="group"
          aria-label="Do you already use Claude Code?"
          data-no-arrow-nav
        >
          <p class="sr-only" id="connect-q">Do you already use Claude Code?</p>
          <button
            type="button"
            class={choiceClass}
            data-choice="claude"
            data-value="yes"
            data-default
            aria-pressed="true"
            aria-describedby="connect-q"
          >
            Yes, I use Claude Code
          </button>
          <button
            type="button"
            class={choiceClass}
            data-choice="claude"
            data-value="no"
            aria-pressed="false"
            aria-describedby="connect-q"
          >
            No, not yet
          </button>
        </div>
        <div class={panelClass} data-choice-panel="claude" data-value="yes">
          Houdini reuses Claude Code's OAuth token straight from the Keychain —
          <strong class="text-text">nothing to configure</strong>. The moment
          it's installed, it's already reading your usage.
        </div>
        <div class={panelClass} data-choice-panel="claude" data-value="no">
          Open Houdini's settings and sign in to claude.ai once, in a secure
          native window. The session is stored in your
          <strong class="text-text">Keychain</strong> and reused — no repeated
          logins, no secret to paste.
        </div>
      </StepCard>

      <!-- 3 · Desktop widget (decision) -->
      <StepCard
        slug="widget"
        index={2}
        total={total}
        badge="3"
        title="Desktop widget"
      >
        <p class="text-sm leading-relaxed text-muted">
          Houdini is one app, and the same data can show up in two places. The
          menu bar is always on. The desktop widget is optional — your call:
        </p>
        <div
          class="mt-5 flex flex-col gap-3 sm:flex-row"
          role="group"
          aria-label="Do you want the desktop widget?"
          data-no-arrow-nav
        >
          <p class="sr-only" id="widget-q">Do you want the desktop widget?</p>
          <button
            type="button"
            class={choiceClass}
            data-choice="widget"
            data-value="yes"
            data-default
            aria-pressed="true"
            aria-describedby="widget-q"
          >
            Yes, put it on my desktop
          </button>
          <button
            type="button"
            class={choiceClass}
            data-choice="widget"
            data-value="no"
            aria-pressed="false"
            aria-describedby="widget-q"
          >
            No, menu bar only
          </button>
        </div>
        <div class={panelClass} data-choice-panel="widget" data-value="yes">
          Turn it on in <strong class="text-text">Settings ▸ Show desktop
          widget</strong>. Drag it by the background, resize from the edges, and
          park it anywhere on your wallpaper — same gauges, same 60-second refresh.
        </div>
        <div class={panelClass} data-choice-panel="widget" data-value="no">
          Just the menu bar, then — <strong class="text-text">always in
          view</strong>, never in the way. You can switch the widget on later in
          Settings whenever you like.
        </div>

        <details
          class="group mt-5 rounded-card border border-border bg-surface/40 p-4"
        >
          <summary
            class="cursor-pointer list-none text-sm font-medium text-muted transition-colors hover:text-text"
          >
            What's included <span class="text-accent">— the two surfaces</span>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-muted">
            Both are the same Houdini — one app, one install. Use one or both.
          </p>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            {
              surfaces.map((s) => (
                <div class="rounded-card border border-border bg-surface/50 p-4">
                  <div class="flex items-center gap-2">
                    <h3 class="text-sm font-semibold">{s.title}</h3>
                    <span class="inline-flex items-center gap-1.5 font-mono text-[11px] text-ok">
                      <span
                        class="h-1.5 w-1.5 rounded-full bg-ok"
                        aria-hidden="true"
                      />
                      Built in
                    </span>
                  </div>
                  <p class="mt-1.5 text-sm leading-relaxed text-muted">
                    {s.body}
                  </p>
                </div>
              ))
            }
          </div>
        </details>
      </StepCard>

      <!-- 4 · You're set (personalised recap) -->
      <StepCard
        slug="done"
        index={3}
        total={total}
        badge="✓"
        title="You're set"
        featured
      >
        <p class="text-sm leading-relaxed text-muted">
          Your tightest limit is now in the menu bar, color-coded and refreshed
          every 60 seconds. Click it for the full popover — every window, its
          reset timer, and any extra-usage spend.
        </p>

        <p class="mt-5 font-mono text-xs uppercase tracking-[0.16em] text-accent">
          Your setup
        </p>
        <ul class="mt-3 space-y-2.5 text-sm leading-relaxed text-muted">
          <li class="flex gap-3" data-recap-when="claude:yes">
            <span class="mt-0.5 shrink-0 text-spark" aria-hidden="true">✓</span>
            <span>
              <strong class="text-text">Claude is connected.</strong> Houdini
              reuses your Claude Code token automatically — nothing to set up.
            </span>
          </li>
          <li class="flex gap-3" data-recap-when="claude:no">
            <span class="mt-0.5 shrink-0 text-spark" aria-hidden="true">✓</span>
            <span>
              <strong class="text-text">Connect Claude.</strong> Open Houdini's
              settings and sign in to claude.ai once — the session stays in your
              Keychain.
            </span>
          </li>
          <li class="flex gap-3" data-recap-when="widget:yes">
            <span class="mt-0.5 shrink-0 text-spark" aria-hidden="true">✓</span>
            <span>
              <strong class="text-text">Desktop widget on.</strong> Enable it in
              Settings ▸ Show desktop widget — drag by the background, resize from
              the edges.
            </span>
          </li>
          <li class="flex gap-3" data-recap-when="widget:no">
            <span class="mt-0.5 shrink-0 text-spark" aria-hidden="true">✓</span>
            <span>
              <strong class="text-text">Menu bar only.</strong> Always in view —
              turn the desktop widget on later if you change your mind.
            </span>
          </li>
        </ul>

        <div
          class="mt-6 rounded-card border border-border bg-surface/40 p-5 text-center"
        >
          <p class="text-sm text-muted">
            New here? The guide walks through what Houdini tracks, how to read
            every gauge, and what stays on your Mac.
          </p>
          <div class="mt-4 flex flex-wrap justify-center gap-3">
            <Button href={links.guide} variant="primary">Read the guide</Button>
            <Button href={links.github} variant="secondary" external>
              View on GitHub
            </Button>
          </div>
        </div>
      </StepCard>
    </Stepper>

    <!-- For developers — discreet, off the main path -->
    <section class="mx-auto mt-10 max-w-3xl px-5 pb-4 sm:px-8">
      <details class="group rounded-card border border-border bg-surface/40 p-5">
        <summary
          class="cursor-pointer list-none text-sm font-medium text-muted transition-colors hover:text-text"
        >
          For developers — build from source <span class="text-accent"
            >Show the commands</span
          >
        </summary>
        <div class="mt-4">
          <p class="text-sm leading-relaxed text-muted">
            Prefer to compile it yourself? Clone the repo and build the app.
            Needs the Xcode Command Line Tools.
          </p>
          <div class="mt-3">
            <CopyBlock code={installFromSource} label="build from source" />
          </div>
        </div>
      </details>
    </section>

    <!-- Closing CTA -->
    <section class="mx-auto mt-2 max-w-3xl px-5 pb-8 sm:px-8">
      <div
        class="relative overflow-hidden rounded-frame ring-grad p-8 text-center sm:p-12"
      >
        <div
          class="spotlight pointer-events-none absolute inset-0 -z-10 opacity-50"
          aria-hidden="true"
        >
        </div>
        <h2 class="font-display text-2xl font-semibold sm:text-3xl">
          Pull your limits into the light.
        </h2>
        <p class="mx-auto mt-3 max-w-md text-muted">
          One line, no Gatekeeper prompt, nothing leaves your Mac.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <Button href={links.guide} variant="primary" size="lg">
            Read the guide
          </Button>
          <Button href={links.github} variant="secondary" size="lg" external>
            View on GitHub
          </Button>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
