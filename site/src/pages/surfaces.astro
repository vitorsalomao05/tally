---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import WindowFrame from "../components/WindowFrame.astro";
import { surfaces } from "../config";
import desktopWidget from "../assets/desktop-widget.png";

const gauges = [
  { label: "5-hour", pct: 34, bar: "bg-ok", text: "text-ok" },
  { label: "Weekly", pct: 72, bar: "bg-warn", text: "text-warn" },
  { label: "Opus weekly", pct: 91, bar: "bg-danger", text: "text-danger" },
];
const menu = surfaces[0];
const widget = surfaces[1];
---

<Layout
  title="Where Houdini shows up — menu bar & desktop widget"
  description="The same Houdini, the same data, the same true 60-second refresh — in your menu bar or pinned to your desktop. Both are built in; pick one or run both."
>
  <main id="main" tabindex="-1" class="screen relative overflow-hidden px-5 pt-24 sm:px-8 md:pt-20">
    <div
      class="screen-glow pointer-events-none absolute -top-20 left-1/2 -z-10 h-[480px] w-[680px] -translate-x-1/2 opacity-70"
      aria-hidden="true"
    >
    </div>

    <div class="screen-inner mx-auto max-w-5xl py-8">
      <div data-enter style="--enter-i: 0">
        <SectionHeader
          eyebrow="Where it shows up"
          title="In the menu bar, on your desktop — one app."
          subtitle="The same Houdini, the same data, the same true 60-second refresh — revealed wherever it fits your workflow. Both are built in; pick one or run both."
          align="left"
        />
      </div>

      <div data-tabs data-enter style="--enter-i: 1" class="mt-9">
        <!-- Segmented toggle -->
        <div
          class="inline-flex rounded-full border border-border bg-surface/50 p-1"
          role="tablist"
          aria-label="Where Houdini shows up"
        >
          <button
            type="button"
            role="tab"
            id="tab-menubar"
            aria-controls="panel-menubar"
            aria-selected="true"
            tabindex="0"
            class="rounded-full px-5 py-2 text-sm font-medium text-muted transition-colors hover:text-text aria-[selected=true]:bg-accent-strong aria-[selected=true]:text-white"
          >
            Menu bar
          </button>
          <button
            type="button"
            role="tab"
            id="tab-widget"
            aria-controls="panel-widget"
            aria-selected="false"
            tabindex="-1"
            class="rounded-full px-5 py-2 text-sm font-medium text-muted transition-colors hover:text-text aria-[selected=true]:bg-accent-strong aria-[selected=true]:text-white"
          >
            Desktop widget
          </button>
        </div>

        <div class="mt-7">
          <!-- Menu bar -->
          <section
            role="tabpanel"
            id="panel-menubar"
            aria-labelledby="tab-menubar"
            tabindex="0"
            class="grid items-center gap-8 rounded-frame border border-border bg-surface/40 p-6 sm:p-8 md:grid-cols-2"
          >
            <div>
              <div class="flex items-center gap-3">
                <h2 class="font-display text-2xl font-semibold sm:text-3xl">Menu bar</h2>
                <span class="inline-flex items-center gap-1.5 font-mono text-xs text-ok">
                  <span class="h-1.5 w-1.5 rounded-full bg-ok" aria-hidden="true"></span>Live · every 60s
                </span>
              </div>
              <p class="mt-3 text-base leading-relaxed text-muted sm:text-lg">{menu.body}</p>
            </div>
            <WindowFrame title="Houdini" glow class="mx-auto w-full max-w-[320px]">
              <div class="space-y-3 p-4">
                {
                  gauges.map((g) => (
                    <div>
                      <div class="flex items-center justify-between">
                        <span class="text-xs text-muted">{g.label}</span>
                        <span class={`font-mono text-xs ${g.text}`}>{g.pct}%</span>
                      </div>
                      <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-surface-2">
                        <div class={`h-full rounded-full ${g.bar}`} style={`width:${g.pct}%`} />
                      </div>
                    </div>
                  ))
                }
              </div>
            </WindowFrame>
          </section>

          <!-- Desktop widget -->
          <section
            role="tabpanel"
            id="panel-widget"
            aria-labelledby="tab-widget"
            tabindex="0"
            class="grid items-center gap-8 rounded-frame border border-border bg-surface/40 p-6 sm:p-8 md:grid-cols-2"
          >
            <div>
              <div class="flex items-center gap-3">
                <h2 class="font-display text-2xl font-semibold sm:text-3xl">Desktop widget</h2>
                <span class="inline-flex items-center gap-1.5 font-mono text-xs text-ok">
                  <span class="h-1.5 w-1.5 rounded-full bg-ok" aria-hidden="true"></span>Live · every 60s
                </span>
              </div>
              <p class="mt-3 text-base leading-relaxed text-muted sm:text-lg">{widget.body}</p>
            </div>
            <Image
              src={desktopWidget}
              alt="Two Houdini desktop widget cards on a wallpaper — a busy account (5-hour and weekly rings, extra-usage spend) and a healthy one — each a glass panel with three-quarter ring gauges and a spend figure."
              widths={[400, 700, 1000]}
              sizes="(max-width: 768px) 90vw, 500px"
              class="mx-auto block w-full rounded-frame border border-border/60 shadow-soft"
              loading="lazy"
            />
          </section>
        </div>
      </div>
    </div>
  </main>
</Layout>
